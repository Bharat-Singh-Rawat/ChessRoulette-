generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String

  rating       Int      @default(1200)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  tokens       Int      @default(50)

  // JSON array of opening IDs (e.g. ["sicilian","ruy_lopez"]). Empty = no preferences.
  preferredOpenings String @default("[]")

  createdAt    DateTime @default(now())

  whiteGames   Game[]   @relation("WhiteGames")
  blackGames   Game[]   @relation("BlackGames")
}

model Game {
  id                 String   @id @default(cuid())
  whiteId            String
  blackId            String
  result             String   // "white_wins" | "black_wins" | "draw"
  reason             String   // checkmate | stalemate | resignation | ...
  whiteRatingBefore  Int
  blackRatingBefore  Int
  whiteRatingAfter   Int
  blackRatingAfter   Int
  finishedAt         DateTime @default(now())

  white User @relation("WhiteGames", fields: [whiteId], references: [id])
  black User @relation("BlackGames", fields: [blackId], references: [id])

  @@index([finishedAt])
  @@index([whiteId])
  @@index([blackId])
}
