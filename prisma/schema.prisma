generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String

  rating       Int      @default(1200)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  tokens       Int      @default(50)

  createdAt    DateTime @default(now())
}
